# Copy to `.env` and fill in. Never commit `.env`.
# All values are read via pydantic-settings (app/config.py) — no os.environ scattered in code.

# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
# Async SQLAlchemy URL (asyncpg driver).
# Running backend INSIDE docker compose: compose overrides host to the `postgres` service.
# Running backend on the host (e.g. uvicorn directly): use localhost as below.
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag

# ─── Azure OpenAI ────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# Leave empty to use Managed Identity (DefaultAzureCredential) instead of API key.
AZURE_OPENAI_API_KEY=
# Data-plane API version (a DATE like 2024-10-21) — NOT a model version.
AZURE_OPENAI_API_VERSION=2024-10-21
# DEPLOYMENT names as created in Azure OpenAI Studio (not raw model names).
# Any chat deployment works (gpt-4o, gpt-4o-mini, ...); gpt-4o-mini is recommended for cost.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ─── Azure AI Search ─────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
# Leave empty to use Managed Identity (DefaultAzureCredential) instead of API key.
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=rag-chunks
# Optional: enable semantic reranker (requires Standard S1+ tier).
# Set to the semantic configuration name created in Azure Portal → Search index → Semantic configurations.
AZURE_SEARCH_SEMANTIC_CONFIG=

# ─── Azure Blob Storage ──────────────────────────────────────────────────────
# FULL connection string from Portal → Storage account → Access keys → "Connection string"
# (looks like: DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net)
# Leave empty to use Managed Identity — then set AZURE_STORAGE_ACCOUNT_URL instead.
AZURE_STORAGE_CONNECTION_STRING=
# Required only when using Managed Identity (no connection string). Example: https://<account>.blob.core.windows.net
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER=documents

# ─── Redis (cache) ───────────────────────────────────────────────────────────
# Leave empty to disable caching (no-op). docker compose sets this automatically.
# Running backend on the host: redis://localhost:6379 (requires Docker Redis running).
REDIS_URL=

# ─── Application Insights ────────────────────────────────────────────────────
# Leave empty to disable telemetry (no-op locally).
# Get from Portal → Application Insights resource → Overview → Connection string.
# Format: InstrumentationKey=<guid>;IngestionEndpoint=https://...;LiveEndpoint=https://...
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ─── App ─────────────────────────────────────────────────────────────────────
# Comma-separated CORS origins. Must list EVERY exact frontend origin (scheme+host+port).
# Auth uses cookies (allow_credentials=True), so "*" is rejected by browsers — list the
# real origins. In production set this to your deployed frontend URL, e.g. https://app.example.com
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
# Set to true in production to redirect HTTP → HTTPS and enable HSTS + security headers.
HTTPS_REDIRECT=false

# ─── Google OAuth (authentication) ──────────────────────────────────────────
# Leave empty to disable auth in local dev (all endpoints public).
# For production: create a project in Google Cloud Console, enable the OAuth2 API,
# create an OAuth client ID (type: Web application), add your domain to allowed origins.
# Both backend and frontend use the same client ID.
GOOGLE_CLIENT_ID=

# ─── Session cookie ──────────────────────────────────────────────────────────
# The session is stored in an HttpOnly cookie. Defaults below suit local dev.
# COOKIE_SECURE=true   → cookie only sent over HTTPS (set in production).
# COOKIE_SAMESITE=lax  → fine when frontend+backend share a site (dev, or nginx proxy).
#   If the deployed frontend and API are on DIFFERENT domains, the browser drops a Lax
#   cookie on credentialed fetch → set COOKIE_SAMESITE=none AND COOKIE_SECURE=true.
# COOKIE_DOMAIN=        → leave empty for host-only; set e.g. .example.com to share across subdomains.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ─── Frontend ────────────────────────────────────────────────────────────────
# Inlined at build time by Next.js — must match GOOGLE_CLIENT_ID above.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Set to true locally or for admins only — exposes the Traces tab in the nav.
NEXT_PUBLIC_SHOW_TRACES=false
